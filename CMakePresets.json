{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Ninja, Release)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "RelWithDebInfo (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "relwithdebinfo-simulation",
      "displayName": "RelWithDebInfo + CodSpeed Simulation (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SPACROW_ENABLE_CODSPEED": "ON",
        "SPACROW_CODSPEED_MODE": "simulation"
      }
    },
    {
      "name": "relwithdebinfo-no-codspeed",
      "displayName": "RelWithDebInfo + No CodSpeed (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "SPACROW_ENABLE_CODSPEED": "OFF",
        "SPACROW_CODSPEED_MODE": "off"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "relwithdebinfo-simulation",
      "configurePreset": "relwithdebinfo-simulation"
    },
    {
      "name": "relwithdebinfo-no-codspeed",
      "configurePreset": "relwithdebinfo-no-codspeed"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "relwithdebinfo-simulation",
      "configurePreset": "relwithdebinfo-simulation",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "relwithdebinfo-no-codspeed",
      "configurePreset": "relwithdebinfo-no-codspeed",
      "output": { "outputOnFailure": true }
    }
  ]
}
